# === QUANT ECOSYSTEM — ENVIRONMENT VARIABLES ===
# Copy this file to .env and fill in your keys

# Claude/Anthropic API — Get free at https://console.anthropic.com
# Required for AI Analyst features
ANTHROPIC_API_KEY=

# FRED API Key — Get free at https://fred.stlouisfed.org/docs/api/api_key.html
# Required for real macro data (yield curve, CPI, etc.)
# Without this key, realistic mock data is shown
FRED_API_KEY=

# Finnhub API Key — Get free at https://finnhub.io (free tier: 60 req/min)
# Powers the VIP Macro Calendar with real economic events, actuals vs forecasts
# Without this key, the calendar shows realistic mock events
FINNHUB_API_KEY=

# Frontend API URL (used when running separately)
VITE_API_URL=http://localhost:8000

# CORS Origins (default: allow all)
ALLOWED_ORIGINS=*
